RewriteEngine On

# Route clean API paths to PHP handlers on Apache/Hostinger shared hosting.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^status$ status.php [L,QSA]
RewriteRule ^chat$ chat.php [L,QSA]
RewriteRule ^chat-expand$ chat-expand.php [L,QSA]
RewriteRule ^roundtable$ roundtable.php [L,QSA]
RewriteRule ^visit$ visit.php [L,QSA]
RewriteRule ^quiz$ quiz.php [L,QSA]
RewriteRule ^quiz-question$ quiz-question.php [L,QSA]
RewriteRule ^admin-stats$ admin-stats.php [L,QSA]
RewriteRule ^profile$ profile.php [L,QSA]
RewriteRule ^subscription$ subscription.php [L,QSA]
RewriteRule ^explain-check$ explain-check.php [L,QSA]
RewriteRule ^guess-paper$ guess-paper.php [L,QSA]
RewriteRule ^book-flashcards$ book-flashcards.php [L,QSA]
RewriteRule ^chapter-notes$ chapter-notes.php [L,QSA]
RewriteRule ^auth/signup$ auth/signup.php [L,QSA]
RewriteRule ^auth/login$ auth/login.php [L,QSA]
RewriteRule ^auth/me$ auth/me.php [L,QSA]
RewriteRule ^auth/logout$ auth/logout.php [L,QSA]
RewriteRule ^auth/request-verification$ auth/request-verification.php [L,QSA]
RewriteRule ^auth/verify-email$ auth/verify-email.php [L,QSA]
RewriteRule ^auth/request-password-reset$ auth/request-password-reset.php [L,QSA]
RewriteRule ^auth/reset-password$ auth/reset-password.php [L,QSA]
