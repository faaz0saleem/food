# Core app
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000

# Hostinger deployment details (fill these on server, not in git)
HOSTINGER_DOMAIN=
HOSTINGER_PUBLIC_HTML_PATH=public_html
HOSTINGER_SSH_HOST=
HOSTINGER_SSH_PORT=22
HOSTINGER_SSH_USER=

# Admin dashboard protection (use a long random secret)
ADMIN_KEY=replace_with_long_random_value
ADMIN_AUTH_MAX_FAILURES=8
ADMIN_AUTH_WINDOW_MS=600000

# API routing/rate limit
RATE_WINDOW_MS=60000
RATE_MAX=20

# AI providers
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_LABEL=llama-3.3-70b-versatile

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# RapidPay
RAPIDPAY_BASE_URL=https://secure.rapid-gateway.com
RAPIDPAY_ENVIRONMENT=TEST
RAPIDPAY_CURRENCY=PKR
RAPIDPAY_MERCHANT_NAME=MindMesh
RAPIDPAY_CLIENT_ID=
RAPIDPAY_CLIENT_SECRET=
RAPIDPAY_MERCHANT_ID=384
RAPIDPAY_AMOUNT_STUDENT=1500
RAPIDPAY_AMOUNT_FAMILY=3500
RAPIDPAY_AMOUNT_SCHOOL=60000
RAPIDPAY_WEBHOOK_TOKEN=
