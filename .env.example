# Example environment variables (do NOT commit real keys)
# Replace values with your real keys in a local .env file (ignored by git)

# GROQ (Groq SDK) / Local LLM provider
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional alternate LLM providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Admin/API settings
ADMIN_KEY=

# Better Auth infrastructure
BETTER_AUTH_API_KEY=

# AI usage controls
FREE_DAILY_MESSAGES_LIMIT=20
ANON_DAILY_AI_LIMIT=3
AI_DAILY_GLOBAL_LIMIT=500

# MySQL (Hostinger/phpMyAdmin backend)
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=

# Server settings
PORT=3000

# Rate limiting (milliseconds and max requests per window)
# Default: 60 seconds window, 20 requests
RATE_WINDOW_MS=60000
RATE_MAX=20
