FALLBACK_NOTIFICATION_EMAIL=ops@example.com
TWILIO_SID=your_twilio_sid
TWILIO_TOKEN=your_twilio_token
WHATSAPP_NUMBER=whatsapp:+14155238886
PAYMENT_MODE=mock
PAYMENT_MERCHANT_ID=merchant_id_here
PAYMENT_CALLBACK_SECRET=replace_me
