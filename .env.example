PORT=3000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/reservationDB
JWT_SECRET=replace_with_long_secret
ADMIN_USER=admin
ADMIN_PASSWORD_HASH=$2a$10$replace_with_bcrypt_hash
DEPOSIT_EXPIRY_MINUTES=15
DEFAULT_DEPOSIT_AMOUNT=1000
