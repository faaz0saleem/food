RewriteEngine On

# Force HTTPS on production hosting.
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP_HOST} !^localhost(:[0-9]+)?$ [NC]
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Canonical host: www -> non-www.
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# admin.hungter.com has its own document root at /public_html/admin.hungter/,
# which serves its own index.html + .htaccess — no host rule needed here.

# Map extensionless API routes to their PHP handlers so the frontend's
# fetch('/api/status') etc. work on Apache/LiteSpeed/Hostinger.
# (No DOCUMENT_ROOT condition — it broke on hosts where the docroot
# variable doesn't match the deployed directory.)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^api/([a-zA-Z0-9_-]+)$ api/$1.php [L]

# Book product pages: a static /books/<id>.html wins when present (the seed
# catalog); admin-added books with no static file fall through to the dynamic
# renderer so /books/<id> always resolves.
RewriteCond %{DOCUMENT_ROOT}/books/$1.html !-f
RewriteRule ^books/([a-zA-Z0-9_-]+)/?$ book-view.php?id=$1 [L,QSA]

# Clean URLs, like every standard site: /about serves about.html, and
# old /about.html links 301 to /about so one canonical URL exists.
RewriteCond %{THE_REQUEST} \s/([^\s?]+)\.html[\s?]
RewriteRule ^ /%1 [R=301,L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^.]+)$ $1.html [L]

ErrorDocument 404 /404.html

# Security headers that netlify.toml handled before.
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header always set Content-Security-Policy "default-src 'self' https: data: blob:; img-src 'self' https: data: blob:; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://cdn.jsdelivr.net https://accounts.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net https://accounts.google.com; font-src 'self' https://fonts.gstatic.com data:; connect-src 'self' https:; frame-src 'self' https://accounts.google.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self'"
</IfModule>

# Block sensitive files and directories from public download.
<FilesMatch "^(\.env|stats\.json|key\.json|.*-key\.json|.*service.*\.json|.*credentials.*\.json|.*\.md|.*\.log)$">
  Require all denied
</FilesMatch>

RedirectMatch 403 ^/\.git
RedirectMatch 403 ^/database/
RedirectMatch 403 ^/phpmyadmin(?:/|$)
RedirectMatch 403 ^/phpMyAdmin-5\.2\.3-all-languages(?:/|$)
# admin.html is protected by its own username/password login + signed tokens
# + per-IP rate limiting (api/admin-api.php) — no blanket block needed.

# Avoid listing directories.
Options -Indexes

# Compression: shrink text responses (~70% smaller) for faster transfer.
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript application/json
  AddOutputFilterByType DEFLATE application/xml application/rss+xml image/svg+xml
  AddOutputFilterByType DEFLATE application/manifest+json font/ttf font/otf
</IfModule>
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/css application/javascript application/json image/svg+xml application/xml
</IfModule>

# Caching: CSS/JS carry ?v= cache-busters so they're safe to cache for a week;
# images/fonts rarely change so cache them for a year. HTML is never cached so
# content updates are instant.
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType application/x-javascript "access plus 7 days"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
  ExpiresByType application/json "access plus 0 seconds"
  ExpiresByType application/xml "access plus 1 hour"
</IfModule>

# Cache-Control for static assets: CSS/JS a week (version-busted), media a year.
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>
  <FilesMatch "\.(png|jpe?g|webp|gif|ico|woff2?|svg)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# Never let browsers cache the service worker itself.
<FilesMatch "^sw\.js$">
  <IfModule mod_headers.c>
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </IfModule>
</FilesMatch>
